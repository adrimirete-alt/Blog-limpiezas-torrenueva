---
import { localidades } from '../data/localidades.js';
---
<footer class="footer">
    <div class="container">
        <div class="footer-grid">
            <div class="footer-col">
                <h3 class="footer-heading">LIMPIEZAS<br>TORRENUEVA</h3>
                <p class="footer-desc">Empresa de limpiezas profesional en Torrevieja y Vega Baja. +15 años especializados en comunidades, garajes, oficinas e industrial.</p>
                <p class="footer-desc" style="margin-top: 1rem;"><strong>4.9 ★ · +200 clientes</strong></p>
            </div>

            <div class="footer-col">
                <h3 class="footer-heading">SERVICIOS</h3>
                <ul class="footer-links-list">
                    <li><a href="/servicios">Limpieza de Comunidades</a></li>
                    <li><a href="/servicios">Limpieza de Garajes</a></li>
                    <li><a href="/servicios">Limpieza de Oficinas</a></li>
                    <li><a href="/servicios">Limpieza Industrial</a></li>
                    <li><a href="/maquinaria">Maquinaria de Limpieza</a></li>
                </ul>
            </div>

            <div class="footer-col">
                <h3 class="footer-heading">ZONAS DE SERVICIO</h3>
                <ul class="footer-links-list">
                    {localidades.slice(0, 7).map(loc => (
                        <li><a href={`/zonas/${loc.slug}`}>{loc.nombre}</a></li>
                    ))}
                    <li><a href="/zonas">Ver todas las zonas →</a></li>
                </ul>
            </div>

            <div class="footer-col">
                <h3 class="footer-heading">CONTACTO</h3>
                <address style="font-style: normal;">
                    <ul class="contact-info-list">
                        <li><a href="tel:+34604438618">📞 +34 604 438 618</a></li>
                        <li><a href="mailto:info@limpiezastorrenueva.com">✉ info@limpiezastorrenueva.com</a></li>
                        <li><a href="https://wa.me/34604438618" target="_blank" rel="noopener">💬 WhatsApp directo</a></li>
                    </ul>
                </address>
                <div class="footer-hours">
                    <strong>Horario:</strong><br>
                    Lunes a Viernes: 8:00 - 19:00<br>
                    Sábado: 9:00 - 14:00
                </div>
            </div>
        </div>

        <div class="footer-bottom">
            <div class="footer-bottom__left">
                <span>© 2026 Limpiezas Torrenueva. Todos los derechos reservados.</span>
            </div>
            <div class="footer-bottom__right">
                <span>CIF: B24909004</span>
                <a href="/aviso-legal">Aviso Legal</a>
                <a href="/privacidad">Privacidad</a>
                <a href="/cookies">Cookies</a>
                <a href="/sitemap-index.xml">Sitemap</a>
            </div>
        </div>
    </div>
</footer>
