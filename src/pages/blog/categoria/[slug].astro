---
import Layout from '../../../layouts/Layout.astro';
import { POSTS_STATIC } from '../../../data/posts-static.js';

const CATEGORIAS = {
    comunidades: { nombre: 'Limpieza de Comunidades', desc: 'Guías y consejos para la limpieza de comunidades de vecinos en Torrevieja y Vega Baja.' },
    garajes: { nombre: 'Limpieza de Garajes', desc: 'Todo lo que necesitas saber sobre limpieza profesional de garajes y parkings.' },
    oficinas: { nombre: 'Limpieza de Oficinas', desc: 'Consejos para mantener tu oficina impecable y productiva.' },
    industrial: { nombre: 'Limpieza Industrial', desc: 'Limpieza de naves industriales y grandes superficies.' },
    maquinaria: { nombre: 'Maquinaria de Limpieza', desc: 'Guías de compra, comparativas y mantenimiento de maquinaria profesional.' },
    zonas: { nombre: 'Zonas de servicio', desc: 'Información sobre limpieza en Torrevieja, Orihuela Costa, Guardamar y resto de Vega Baja.' },
    consejos: { nombre: 'Consejos Prácticos', desc: 'Trucos y consejos profesionales para una limpieza eficaz.' },
};

export async function getStaticPaths() {
    const cats = ['comunidades', 'garajes', 'oficinas', 'industrial', 'maquinaria', 'zonas', 'consejos'];
    return cats.map(slug => ({ params: { slug } }));
}

const { slug } = Astro.params;
const categoria = CATEGORIAS[slug];
const posts = POSTS_STATIC.filter(p => p.category === slug);
---
<Layout
    title={`${categoria.nombre} en Torrevieja | Blog Limpiezas Torrenueva`}
    description={categoria.desc}
>
    <main>
        <section class="page-hero">
            <div class="page-hero__bg" style="background: linear-gradient(135deg, #1e40af 0%, #3b82f6 100%);">
                <div class="page-hero__overlay" style="background: rgba(0,0,0,0.2);"></div>
            </div>
            <div class="container page-hero__content">
                <nav aria-label="Migas de pan" style="margin-bottom: 1rem; font-size: 0.9rem; color: rgba(255,255,255,0.85);">
                    <a href="/" style="color: inherit;">Inicio</a> ›
                    <a href="/blog" style="color: inherit;">Blog</a> › <span>{categoria.nombre}</span>
                </nav>
                <h1 class="page-hero__title">{categoria.nombre}</h1>
                <p class="page-hero__subtitle">{categoria.desc}</p>
            </div>
        </section>

        <section class="section-padding">
            <div class="container">
                {posts.length > 0 ? (
                    <div class="services__grid">
                        {posts.map(post => (
                            <article class="service-card">
                                <div class="service-card__image">
                                    <img src={post.image_url || '/blog-comunidades.png'} alt={post.title} loading="lazy" style="width: 100%; height: 220px; object-fit: cover;">
                                </div>
                                <div class="service-card__content">
                                    <h2 class="service-card__title" style="font-size: 1.2rem;">{post.title}</h2>
                                    <p class="service-card__desc">{post.description}</p>
                                    <a href={`/post/${post.slug}`} class="link-arrow">Leer →</a>
                                </div>
                            </article>
                        ))}
                    </div>
                ) : (
                    <div style="text-align: center; padding: 3rem; color: #64748b;">
                        <p>Aún no hay artículos en esta categoría. <a href="/blog" style="color: #3b82f6;">Ver todos →</a></p>
                    </div>
                )}
            </div>
        </section>
    </main>
</Layout>
