---
import Layout from '../../layouts/Layout.astro';
import { categoriasMaquinaria, getCategoria } from '../../data/maquinaria.js';

export function getStaticPaths() {
    return categoriasMaquinaria.map(cat => ({ params: { categoria: cat.slug } }));
}

const { categoria } = Astro.params;
const data = getCategoria(categoria);

if (!data) return Astro.redirect('/maquinaria');

const breadcrumbSchema = {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://limpiezastorrenueva.com/" },
        { "@type": "ListItem", "position": 2, "name": "Maquinaria", "item": "https://limpiezastorrenueva.com/maquinaria" },
        { "@type": "ListItem", "position": 3, "name": data.nombre, "item": `https://limpiezastorrenueva.com/maquinaria/${data.slug}` }
    ]
};

const productSchema = {
    "@context": "https://schema.org",
    "@type": "OfferCatalog",
    "name": data.nombre,
    "description": data.intro,
    "itemListElement": data.modelos.map((m, i) => ({
        "@type": "Offer",
        "position": i + 1,
        "itemOffered": { "@type": "Product", "name": m.nombre, "description": m.desc, "image": m.img }
    }))
};
---
<Layout title={data.titulo_seo} description={data.meta}>
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} slot="head" />
    <script type="application/ld+json" set:html={JSON.stringify(productSchema)} slot="head" />

    <main>
        <section class="page-hero">
            <div class="page-hero__bg" style="background: linear-gradient(135deg, #1e40af 0%, #3b82f6 100%);">
                <div class="page-hero__overlay"></div>
            </div>
            <div class="container page-hero__content">
                <nav aria-label="Migas de pan" style="margin-bottom: 1rem; font-size: 0.9rem; color: rgba(255,255,255,0.85);">
                    <a href="/" style="color: inherit;">Inicio</a> ›
                    <a href="/maquinaria" style="color: inherit;">Maquinaria</a> › <span>{data.nombre}</span>
                </nav>
                <h1 class="page-hero__title">{data.h1}</h1>
                <p class="page-hero__subtitle">{data.intro}</p>
            </div>
        </section>

        <section class="section-padding">
            <div class="container">
                <div class="section-header center-text" style="margin-bottom: 3rem;">
                    <span class="section-tag">Modelos disponibles</span>
                    <h2 class="section-title">Nuestra gama de {data.nombre.toLowerCase()}</h2>
                </div>

                <div class="services__grid">
                    {data.modelos.map(modelo => (
                        <article class="service-card">
                            <div class="service-card__image">
                                <img src={modelo.img} alt={modelo.nombre} loading="lazy">
                            </div>
                            <div class="service-card__content">
                                <h3 class="service-card__title">{modelo.nombre}</h3>
                                <p class="service-card__desc">{modelo.desc}</p>
                                <ul style="list-style: none; padding: 0; margin: 1rem 0; display: flex; flex-direction: column; gap: 0.4rem; font-size: 0.875rem; color: #64748b;">
                                    {modelo.specs.map(spec => (
                                        <li><span style="color: #3b82f6; font-weight: 700;">✓</span> {spec}</li>
                                    ))}
                                </ul>
                                <a href="/contacto" class="link-arrow">Pedir presupuesto <span>→</span></a>
                            </div>
                        </article>
                    ))}
                </div>
            </div>
        </section>

        <section class="section-padding" style="background: #f8fafc;">
            <div class="container" style="max-width: 1000px;">
                <div class="grid grid--2-cols" style="gap: 3rem; align-items: start;">
                    <div>
                        <span class="section-tag">Ventajas</span>
                        <h2 class="section-title" style="margin-bottom: 1.5rem;">¿Por qué elegir estos equipos?</h2>
                        <ul class="features-list">
                            {data.beneficios.map(b => (
                                <li class="features-list__item"><span class="check-icon">✓</span> {b}</li>
                            ))}
                        </ul>
                    </div>
                    <div>
                        <span class="section-tag">Aplicaciones</span>
                        <h2 class="section-title" style="margin-bottom: 1.5rem;">¿Dónde se usan?</h2>
                        <ul class="features-list">
                            {data.aplicaciones.map(a => (
                                <li class="features-list__item"><span class="check-icon">›</span> {a}</li>
                            ))}
                        </ul>
                    </div>
                </div>
            </div>
        </section>

        <section class="section-padding bg-dark text-white" style="background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%);">
            <div class="container" style="max-width: 800px; text-align: center;">
                <h2 style="color: white; font-size: 2rem; margin-bottom: 1rem;">Pide tu presupuesto sin compromiso</h2>
                <p style="opacity: 0.9; margin-bottom: 2rem;">Te asesoramos sobre el modelo perfecto para tu negocio y te ofrecemos las mejores condiciones del mercado.</p>
                <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
                    <a href="tel:+34604438618" class="button button--white">☎ 604 438 618</a>
                    <a href="/contacto" class="button button--outline" style="border-color: white; color: white;">Formulario</a>
                </div>
            </div>
        </section>
    </main>
</Layout>
