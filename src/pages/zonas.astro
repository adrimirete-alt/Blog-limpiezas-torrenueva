---
import Layout from '../layouts/Layout.astro';
import '../styles/zonas.css';
import { localidades } from '../data/localidades.js';
---
<Layout
    title="Zonas de Servicio: Limpiezas en Torrevieja y Vega Baja | Torrenueva"
    description="Empresa de limpiezas en Torrevieja, Orihuela Costa, La Zenia, Campoamor, Guardamar, Rojales, Almoradí, San Fulgencio, La Marina, Los Montesinos y toda la Vega Baja. ☎ 604 438 618"
>
    <main>
        <!-- Page Hero -->
        <section class="page-hero">
            <div class="page-hero__bg">
                <img src="/zonas-hero.png" alt="Mapa de zonas de servicio en Torrevieja y Vega Baja" class="page-hero__img" loading="eager">
            </div>
            <div class="page-hero__overlay"></div>
            <div class="container page-hero__content">
                <h1 class="page-hero__title">Zonas de Servicio en Torrevieja y Vega Baja</h1>
                <p class="page-hero__subtitle">Limpieza profesional en Torrevieja y toda la comarca de la Vega Baja del Segura.</p>
            </div>
        </section>

        <!-- Main Content with Sticky Map -->
        <section class="section-padding">
            <div class="container">
                <div class="grid grid--2-cols" style="align-items: start; gap: 4rem;">
                    
                    <!-- Left Column: Content Cards -->
                    <div class="zones-content">
                        <div class="section-header" style="text-align: center; margin-bottom: 2rem;">
                            <span class="section-tag">Cobertura</span>
                            <h2 class="section-title" style="font-size: clamp(1.9rem, 4.75vw, 3.3rem); white-space: nowrap;">Nuestra Zona de Acción</h2>
                            <p class="text-body" style="text-align: center; max-width: 700px; margin: 0 auto 3rem auto;">Llegamos allí donde nos necesite. Nuestra logística nos permite cubrir eficazmente toda la zona costera y el interior de la Vega Baja.</p>
                        </div>

                        {localidades.map(loc => (
                            <a href={`/zonas/${loc.slug}`} class="zone-card" style="display: block; background: white; padding: 2rem; border-radius: 12px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05); margin-bottom: 1.5rem; border-left: 4px solid #3b82f6; text-decoration: none; color: inherit; transition: all 0.2s;">
                                <h3 style="font-size: 1.35rem; margin-bottom: 0.5rem; color: #1e293b;">Limpiezas en {loc.nombre}</h3>
                                <p style="color: #64748b; margin-bottom: 0.75rem;">{loc.descripcion_corta}</p>
                                <span style="color: #3b82f6; font-weight: 600; font-size: 0.9rem;">Ver detalles →</span>
                            </a>
                        ))}

                    </div>

                    <!-- Right Column: Sticky Map -->
                    <div class="zones-map-wrapper" style="position: sticky; top: 100px;">
                        <img src="/mapa-torrevieja.png" alt="Mapa de Cobertura" style="width: 100%; border-radius: 12px; box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1); transform: scale(1.1); transform-origin: top center; margin-bottom: 20px;">
                        <div style="margin-top: 2rem; text-align: center; font-size: 0.9rem; color: #64748b;">
                            * Mapa orientativo de nuestra zona principal de actuación.
                        </div>
                    </div>

                </div>
            </div>
        </section>

        <!-- Process Section -->
<!-- TARJETAS CON FLECHAS PROCESO - VERSAR LINEAL -->
        <section class="proceso-section">
          <div class="container">
            <h2 class="proceso-title">PROCESO</h2>
            
            <div class="proceso-cards">
              <!-- Tarjeta 1 -->
              <div class="proceso-card">
                <div class="card-number">1</div>
                <div class="card-icon">
                    <img src="/icons/phone.svg" alt="Contacto">
                </div>
                <h3>Llámenos o Escríbanos</h3>
                <p>Atendemos su solicitud rápidamente.</p>
              </div>
              
              <!-- Flecha -->
              <div class="arrow">→</div>
              
              <!-- Tarjeta 2 -->
              <div class="proceso-card">
                <div class="card-number">2</div>
                <div class="card-icon">
                    <img src="/icons/eye.svg" alt="Visita">
                </div>
                <h3>Visitamos las Instalaciones</h3>
                <p>Visitamos las instalaciones para valorar el trabajo in situ.</p>
              </div>
              
              <!-- Flecha -->
              <div class="arrow">→</div>
              
              <!-- Tarjeta 3 -->
              <div class="proceso-card">
                <div class="card-number">3</div>
                <div class="card-icon">
                    <img src="/icons/clipboard.svg" alt="Presupuesto">
                </div>
                <h3>Presupuesto Detallado</h3>
                <p>Le entregamos un presupuesto detallado y sin compromiso.</p>
              </div>
              
              <!-- Flecha -->
              <div class="arrow">→</div>
              
              <!-- Tarjeta 4 -->
              <div class="proceso-card">
                <div class="card-number">4</div>
                <div class="card-icon">
                    <img src="/icons/star.svg" alt="Inicio">
                </div>
                <h3>Comenzamos el Servicio</h3>
                <p>Comenzamos el servicio en la fecha y hora acordadas.</p>
              </div>
            </div>
          </div>
        </section>

        <!-- CTA Blue Section -->
        <section class="section-padding bg-primary text-white">
            <div class="container">
                <div class="cta-blue-content-wrapper" style="display: flex; align-items: center; justify-content: space-between; gap: 4rem;">
                    
                    <!-- Text Side (Smaller now) -->
                    <div class="cta-blue-text" style="flex: 1; background-color: #F0F9FF; padding: 3rem; border-radius: 20px; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05); max-width: 45%;">
                        <h2 class="cta-blue-title" style="font-size: 2rem; margin-bottom: 1.5rem; color: #1e293b; line-height: 1.2;">SU CONFIANZA, NUESTRO ÉXITO</h2>
                        <p class="cta-blue-subtitle" style="font-size: 1.1rem; opacity: 0.9; color: #475569; margin-bottom: 2rem; line-height: 1.6;">
                            Garantizamos una limpieza profesional de máxima calidad. Si el resultado no cumple con sus expectativas, nos comprometemos a repasar el trabajo inmediatamente sin ningún coste adicional para usted.
                        </p>
                        
                        <!-- Linea SEO -->
                        <div style="margin-bottom: 2rem; padding-left: 1rem; border-left: 4px solid #3b82f6; color: #0f172a; font-weight: 600; font-size: 1rem; line-height: 1.5;">
                            Somos la empresa líder y de confianza para servicios de limpieza integral en Torrevieja, Orihuela Costa y toda la comarca de la Vega Baja.
                        </div>

                        <a href="/contacto" class="button button--primary" style="background-color: #1d4ed8; color: white;">Contactar Ahora</a>
                    </div>
                    
                    <!-- Image Side (Larger) -->
                    <div class="cta-blue-image" style="flex: 1.3; position: relative;">
                        <!-- Image Container -->
                        <div style="position: relative; border-radius: 12px; overflow: hidden; box-shadow: 0 10px 25px rgba(0,0,0,0.2);">
                            <img src="/cleaner_thumbs_up.png" alt="Limpiador profesional" style="width: 100%; height: auto; display: block;">
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>
</Layout>
