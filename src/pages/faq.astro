---
import Layout from '../layouts/Layout.astro';

const faqs = [
    { q: "¿Qué servicios de limpieza ofrecen en Torrevieja?", a: "Ofrecemos una amplia gama de servicios especializados: limpieza de comunidades de vecinos, mantenimiento de garajes y parkings, limpieza de cristales en altura, limpieza de oficinas y grandes superficies, así como tratamientos de suelos (abrillantado y pulido)." },
    { q: "¿Cubren la zona de Vega Baja?", a: "Sí, nuestra base está en Torrevieja pero prestamos servicio en toda la comarca de la Vega Baja, incluyendo Orihuela Costa, Guardamar del Segura, Rojales, Pilar de la Horadada y alrededores." },
    { q: "¿Ofrecen presupuestos gratuitos?", a: "Sí, totalmente gratuitos y sin compromiso. Nos desplazamos a sus instalaciones para evaluar el trabajo y ofrecerle la mejor solución personalizada." },
    { q: "¿Cuál es el plazo máximo de ejecución de los trabajos?", a: "El plazo depende de la envergadura del proyecto. Para mantenimientos, establecemos un calendario periódico. Para limpiezas puntuales o de fin de obra, intentamos iniciar el trabajo en un plazo de 24-48 horas tras la aceptación del presupuesto." },
    { q: "¿Qué productos de limpieza utilizan?", a: "Utilizamos exclusivamente productos profesionales de alta eficacia, respetuosos con el medio ambiente y específicos para cada tipo de superficie, garantizando resultados óptimos sin dañar los materiales." },
    { q: "¿Tienen maquinaria profesional para trabajos grandes?", a: "Sí, contamos con flota propia de maquinaria industrial: fregadoras de conductor sentado y manuales, hidrolimpiadoras de alta presión, aspiradoras industriales y equipos de limpieza de cristales en altura." },
    { q: "¿Ofrecen servicios de urgencia?", a: "Estudiamos casos de urgencia (inundaciones, siniestros, limpiezas express) fuera de nuestro horario habitual para dar respuesta a necesidades críticas de nuestros clientes." },
    { q: "¿Cómo puedo contactar con Limpiezas Torrenueva?", a: "Puede llamarnos al 604 438 618, enviarnos un email a info@limpiezastorrenueva.com o utilizar el formulario de contacto de esta web. También atendemos por WhatsApp." },
    { q: "¿Están asegurados y certificados?", a: "Por supuesto. Cumplimos con toda la normativa vigente en prevención de riesgos laborales y contamos con seguro de Responsabilidad Civil para garantizar la tranquilidad total de nuestros clientes." }
];

const faqSchema = {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
    }))
};
---
<Layout
    title="Preguntas Frecuentes sobre Limpieza en Torrevieja | Torrenueva"
    description="Resolvemos tus dudas sobre limpieza de comunidades, garajes, oficinas y servicios en Torrevieja y Vega Baja. Presupuesto sin compromiso ☎ 604 438 618"
>
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} slot="head" />
    <main>
        <!-- Page Hero -->
        <section class="page-hero">
            <div class="page-hero__bg">
                <img src="/faq_hero_laptop.png" alt="Preguntas frecuentes sobre servicios de limpieza en Torrevieja" class="page-hero__img" loading="eager">
            </div>
            <div class="page-hero__overlay"></div>
            <div class="container page-hero__content">
                <h1 class="page-hero__title">Preguntas Frecuentes sobre Limpieza en Torrevieja</h1>
                <p class="page-hero__subtitle">Resolvemos tus dudas sobre nuestros servicios de limpieza en Torrevieja y la Vega Baja.</p>
            </div>
        </section>

        <section class="section-padding faq-section">
            <div class="container">
                <div class="grid grid--2-cols" style="align-items: start; gap: 4rem;">
                    
                    <!-- Left Column: FAQ List -->
                    <div class="faq-wrapper">
                        <!-- Q1 -->
                        <details class="faq-item">
                            <summary class="faq-question">¿Qué servicios de limpieza ofrecen en Torrevieja?</summary>
                            <div class="faq-answer">
                                <p>Ofrecemos una amplia gama de servicios especializados: limpieza de comunidades de vecinos, mantenimiento de garajes y parkings, limpieza de cristales en altura, limpieza de oficinas y grandes superficies, así como tratamientos de suelos (abrillantado y pulido).</p>
                            </div>
                        </details>

                        <!-- Q2 -->
                        <details class="faq-item">
                            <summary class="faq-question">¿Cubren la zona de Vega Baja?</summary>
                            <div class="faq-answer">
                                <p>Sí, nuestra base está en Torrevieja pero prestamos servicio en toda la comarca de la Vega Baja, incluyendo Orihuela Costa, Guardamar del Segura, Rojales, Pilar de la Horadada y alrededores.</p>
                            </div>
                        </details>

                        <!-- Q3 -->
                        <details class="faq-item">
                            <summary class="faq-question">¿Ofrecen presupuestos gratuitos?</summary>
                            <div class="faq-answer">
                                <p>Sí, totalmente gratuitos y sin compromiso. Nos desplazamos a sus instalaciones para evaluar el trabajo y ofrecerle la mejor solución personalizada.</p>
                            </div>
                        </details>

                        <!-- Q4 -->
                        <details class="faq-item">
                            <summary class="faq-question">¿Cuál es el plazo máximo de ejecución de los trabajos?</summary>
                            <div class="faq-answer">
                                <p>El plazo depende de la envergadura del proyecto. Para mantenimientos, establecemos un calendario periódico. Para limpiezas puntuales o de fin de obra, intentamos iniciar el trabajo en un plazo de 24-48 horas tras la aceptación del presupuesto, siempre cumpliendo con los plazos acordados.</p>
                            </div>
                        </details>

                        <!-- Q5 -->
                        <details class="faq-item">
                            <summary class="faq-question">¿Qué productos de limpieza utilizan?</summary>
                            <div class="faq-answer">
                                <p>Utilizamos exclusivamente productos profesionales de alta eficacia, respetuosos con el medio ambiente y específicos para cada tipo de superficie, garantizando resultados óptimos sin dañar los materiales.</p>
                            </div>
                        </details>

                        <!-- Q6 -->
                        <details class="faq-item">
                            <summary class="faq-question">¿Tienen maquinaria profesional para trabajos grandes?</summary>
                            <div class="faq-answer">
                                <p>Sí, contamos con flota propia de maquinaria industrial: fregadoras de conductor sentado y manuales, hidrolimpiadoras de alta presión, aspiradoras industriales y equipos de limpieza de cristales en altura.</p>
                            </div>
                        </details>

                        <!-- Q7 -->
                        <details class="faq-item">
                            <summary class="faq-question">¿Ofrecen servicios de urgencia?</summary>
                            <div class="faq-answer">
                                <p>Estudiamos casos de urgencia (inundaciones, siniestros, limpiezas express) fuera de nuestro horario habitual para dar respuesta a necesidades críticas de nuestros clientes.</p>
                            </div>
                        </details>
                        
                        <!-- Q8 -->
                        <details class="faq-item">
                            <summary class="faq-question">¿Cómo puedo contactar con Limpiezas Torrenueva?</summary>
                            <div class="faq-answer">
                                <p>Puede llamarnos al 604 438 618, enviarnos un email a info@limpiezastorrenueva.com o utilizar el formulario de contacto de esta web. También atendemos por WhatsApp.</p>
                            </div>
                        </details>

                        <!-- Q9 -->
                        <details class="faq-item">
                            <summary class="faq-question">¿Están asegurados y certificados?</summary>
                            <div class="faq-answer">
                                <p>Por supuesto. Cumplimos con toda la normativa vigente en prevención de riesgos laborales y contamos con seguro de Responsabilidad Civil para garantizar la tranquilidad total de nuestros clientes.</p>
                            </div>
                        </details>
                    </div>

                    <!-- Right Column: Image -->
                    <div class="faq-image-wrapper" style="position: sticky; top: 120px;">
                        <img src="/thoughtful_person_faq.png" alt="Persona pensando dudas" 
                            style="width: 100%; border-radius: 12px; box-shadow: 0 10px 25px -5px rgba(0,0,0,0.1); margin-bottom: 2rem;">
                        
                        <div class="cta-box bg-primary text-white" style="padding: 2rem; border-radius: 12px; text-align: center;">
                            <h3 style="color: white; margin-bottom: 1rem;">¿Tienes más dudas?</h3>
                            <p style="margin-bottom: 1.5rem; opacity: 0.9;">Nuestro equipo está listo para responder cualquier otra pregunta que tengas.</p>
                            <a href="/contacto" class="button button--white" style="width: 100%;">Contactar Ahora</a>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>
</Layout>
